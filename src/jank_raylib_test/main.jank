(ns jank-raylib-test.main)

(cpp/raw "

#include <RaylibWrapper/c_api.h>

void run()
{
    const int screenWidth = 800;
    const int screenHeight = 450;

    rlw_InitWindow(screenWidth, screenHeight, \"raylib [core] example - basic window\");

    rlw_SetTargetFPS(60);

    while (!rlw_WindowShouldClose())
    {
        rlw_BeginDrawing();

            rlw_ClearBackground(RAYWHITE);

            rlw_DrawText(\"Congrats! You created your first window!\", 190, 200, 20, LIGHTGRAY);

        rlw_EndDrawing();
    }

    rlw_CloseWindow();
}

")

(defn -main [& args]
  (cpp/run))
